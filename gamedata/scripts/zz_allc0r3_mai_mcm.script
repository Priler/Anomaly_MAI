    monolith_ignore_restrictions = false,
}


-- [ Helpers ]--

-- Options are grouped into MCM subcategories (sh = true). Subcategorizing nests the stored
-- key as "mai/<group>/<id>", so get_config rebuilds that path from a flat id -- every call
-- site (main script, loot_guard, etc.) keeps passing the bare option id, unaware of the group.
local OPTION_GROUP = {}
local function assign_group(group, ids)
    for i = 1, #ids do OPTION_GROUP[ids[i]] = group end
end
assign_group("general",   { "mod_enabled", "debug_mode", "verbose_debug", "show_debug_anomalies",
                            "cleanup_map_markers", "debug_death_news", "debug_death_map_spot" })
assign_group("detection", { "base_detection_radius", "cache_rebuild_delay", "bubble_enabled",
                            "bubble_radius", "restrictions_ignore_radius", "anomaly_memory_decay",
                            "legacy_anomaly_ignores" })
assign_group("avoidance", { "npc_stuck_timeout", "engine_avoidance", "engine_feel_max_density" })
assign_group("damage",    { "enable_armor_damage_mult", "immune_zero_miss_chance", "combat_only_damage",
                            "block_anomalies_on_corpses", "block_corpse_loot_in_anomalies" })
assign_group("movement",  { "walking_immunity", "safe_grace_period", "standing_miss_multiplier",
                            "walking_miss_multiplier", "running_miss_multiplier", "combat_miss_multiplier" })
assign_group("ranks",     { "rank_novice_miss_chance", "rank_trainee_miss_chance", "rank_experienced_miss_chance",
                            "rank_professional_miss_chance", "rank_veteran_miss_chance", "rank_expert_miss_chance",
                            "rank_master_miss_chance", "rank_legend_miss_chance" })
assign_group("killrate",  { "kill_rate_limit", "kill_cap_global",
                            "kill_cap_faction_stalker", "kill_cap_faction_bandit", "kill_cap_faction_dolg",
                            "kill_cap_faction_freedom", "kill_cap_faction_monolith", "kill_cap_faction_army",
                            "kill_cap_faction_ecolog", "kill_cap_faction_killer", "kill_cap_faction_greh",
                            "kill_cap_faction_renegade", "kill_cap_faction_isg", "kill_cap_faction_csky",
                            "kill_cap_faction_zombied",
                            "kill_cap_rank_novice", "kill_cap_rank_trainee", "kill_cap_rank_experienced",
                            "kill_cap_rank_professional", "kill_cap_rank_veteran", "kill_cap_rank_expert",
                            "kill_cap_rank_master", "kill_cap_rank_legend" })
assign_group("community", { "greh_ignore_damage", "greh_ignore_restrictions",
                            "monolith_ignore_damage", "monolith_ignore_restrictions" })

local function full_key(key)
    local g = OPTION_GROUP[key]
    if g then return "mai/" .. g .. "/" .. key end
    return "mai/" .. key
end

function get_config(key)
    if ui_mcm then
        return ui_mcm.get(full_key(key))
    end
    return defaults[key]
end

function mcm_available()
    return ui_mcm ~= nil
end


-- [ Menu ]--

-- One subcategory page: an sh=true group whose first child is a slide header. `text` is reused
-- for both the sidebar label and the slide so each page needs no extra string ids.
local function subcategory(id, title_key, options)
    local gr = {
        { id = "slide_" .. id, type = "slide", link = "ui_options_slider_player",
          text = title_key, size = {512, 50}, spacing = 20 },
    }
    for i = 1, #options do
        local opt = options[i]
        -- Nesting under a tab makes MCM derive each option's label string id from the full
        -- path (ui_mcm_mai_<tab>_<id>). Pin it back to the flat ui_mcm_mai_<id> the string
        -- table already defines: hint replaces everything after the ui_mcm_ prefix, and the
        -- tooltip then resolves to hint .. "_desc". One hint per option, no per-option edits.
        if opt.id and opt.hint == nil then opt.hint = "mai_" .. opt.id end
        gr[#gr + 1] = opt
    end
    return { id = id, sh = true, text = title_key, gr = gr }
end

function on_mcm_load()
    return {
        id = "mai",
        gr = {
            subcategory("general", "ui_mcm_mai_general_title", {
                { id = "mod_enabled",           type = "check", val = 1, def = true },
